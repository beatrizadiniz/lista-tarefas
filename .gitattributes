# Auto detect text files and use LF
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Shell scripts
*.sh text eol=lf

# PowerShell
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
